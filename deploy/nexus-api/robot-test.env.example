# robot-test deployment environment example
#
# 1. Copy this file to `robot-test.env`
# 2. Fill in the real values on the target machine
# 3. Before deploy, load it with:
#    export $(grep -v '^#' deploy/nexus-api/robot-test.env | xargs)

# PostgreSQL connection for orchestration/history persistence.
# If PostgreSQL runs on the deployment host, the container can reach it by
# `host.docker.internal`.
NEXUS_DATABASE__DSN=postgresql://postgres:postgres@host.docker.internal:5432/nexus_api

# Optional robot list endpoint reused from another project.
# Leave empty to use local fallback options.
NEXUS_ORCHESTRATION__ROBOT_ENDPOINT=
